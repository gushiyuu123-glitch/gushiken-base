{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "trailingSlash": false,

  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/offline.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],

  "redirects": [
    {
      "source": "/okinawa-bridal-website",
      "destination": "/works/vow-in-light",
      "permanent": true
    },
    {
      "source": "/naha-ryukyu-costume-website",
      "destination": "/works/kou-ryui",
      "permanent": true
    },
    {
      "source": "/okinawa-night-website",
      "destination": "/works/black-papillon",
      "permanent": true
    }
  ],

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}