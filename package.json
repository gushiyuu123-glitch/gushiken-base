{
  "name": "gushiken-base",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "dev": "vite",

    "prebuild": "npm run bump-sw && npm run generate-sitemap",
