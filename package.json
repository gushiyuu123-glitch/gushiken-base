    "build:check": "npm run lint && npm run build",

    "bump-sw": "node scripts/bump-sw-stamp.cjs",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "check-no-touch": "node scripts/check-no-touch.cjs",

    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",

    "preview": "vite preview",
    "prepare": "husky install"
  },
  "dependencies": {
    "@vercel/analytics": "^1.6.1",
    "axios": "^1.15.0",
    "curtainsjs": "^8.1.6",
    "gsap": "^3.15.0",
    "jquery": "^4.0.0",
    "jquery.ripples": "^0.6.3",
    "lenis": "^1.3.23",
    "microcms-js-sdk": "^3.2.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.9.6",
    "three": "^0.184.0",
    "three-fluid-fx": "^0.1.0",
    "vanta": "^0.5.24"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "autoprefixer": "^10.4.22",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^8.0.0",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.6",
    "sitemap": "^9.0.0",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.2",
    "vitest": "^4.1.7"
